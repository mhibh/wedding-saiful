# Google Sheets CSV URL
# ──────────────────────────────────────────────────
# 1. Buat Google Sheet dengan kolom: slug | nama | no_wa
# 2. File → Bagikan → Publikasikan ke web → CSV → Publikasikan
# 3. Salin URL CSV dan tempel di sini
NEXT_PUBLIC_SHEETS_CSV_URL=

